#stem\\.gitignore", "content": "# Java
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# VS Code
.vscode/
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.vscode/extensions.json
*.code-workspace

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# Eclipse
.project
.classpath
.settings/
bin/

# Spring Boot
*.log
spring-boot-output.log
mvn-output.log

# Application Config (contains sensitive credentials)
application.properties
application-*.properties
!application-example.properties
!application.yml

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Environment
.env
.env.local
.env.*.local

# Logs and databases
*.log
*.sqlite
*.db
dump.rdb

# Node (if any frontend in the future)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temp files
*.tmp
*.swp
*.swo
*~
~$*

# BlueJ
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs
hs_err_pid*
replay_pid*
"}

# Python backend
backend-python/.venv/
backend-python/*.bak

# 自定义配置文件（包含敏感信息，不上传）
backend-python/config.ini

# TTS 生成的语音文件（仅保留目录，不上传音频）
voice-files/*.wav